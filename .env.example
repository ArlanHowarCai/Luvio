# 模型
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# 如果用 DeepSeek 做分析 Agent，优先填写这两个
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

# 行情源，任意配置一个即可。港股免费兜底会优先尝试 Tencent Finance 公开接口。
ALPHAVANTAGE_API_KEY=
TWELVEDATA_API_KEY=
FINNHUB_API_KEY=

# 财务数据源（免费 250 次/天，覆盖财报、估值、分析师评级）
FMP_API_KEY=

# 新闻增强（设为 1 启用 Google News RSS）
LUVIO_ENABLE_GOOGLE_NEWS=

# 网页证据层（推荐至少配置一个，用于自动搜索公开资料并缓存到 SQLite）
TAVILY_API_KEY=
SERPAPI_API_KEY=
